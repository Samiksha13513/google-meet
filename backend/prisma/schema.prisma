generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  image     String?
  googleId  String?  @unique
  createdAt DateTime @default(now())

  meetings  Meeting[]
  callsMade     Call[]      @relation("CallCaller")
  callsReceived Call[]      @relation("CallReceiver")
  callHistoriesInitiated CallHistory[] @relation("CallerHistory")
  callHistoriesReceived  CallHistory[] @relation("ReceiverHistory")
}

model Meeting {
  id           String   @id @default(cuid())
  meetingCode  String   @unique
  hostId       String
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  host User @relation(fields: [hostId], references: [id])
}

model Call {
  id         String   @id @default(cuid())
  callerId   String
  receiverId String
  type       String   // "audio" | "video"
  status     String   // "ringing" | "completed" | "missed" | "rejected" | "cancelled"
  startedAt  DateTime?
  endedAt    DateTime?
  duration   Int?     // in seconds
  createdAt  DateTime @default(now())

  caller   User @relation("CallCaller", fields: [callerId], references: [id])
  receiver User @relation("CallReceiver", fields: [receiverId], references: [id])
  histories CallHistory[]
}

model CallHistory {
  id        String   @id @default(cuid())
  callId    String
  callerId  String
  receiverId String
  status    String
  duration  Int?
  createdAt DateTime @default(now())

  call Call @relation(fields: [callId], references: [id])
  caller   User @relation("CallerHistory", fields: [callerId], references: [id])
  receiver User @relation("ReceiverHistory", fields: [receiverId], references: [id])
}