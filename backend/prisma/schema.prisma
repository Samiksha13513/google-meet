generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  avatar    String?
  image     String?
  googleId  String?  @unique
  createdAt DateTime @default(now())

  meetings      Meeting[]
  participations MeetingParticipant[]
  callsMade     Call[]      @relation("CallCaller")
  callsReceived Call[]      @relation("CallReceiver")
  callHistoriesInitiated CallHistory[] @relation("CallerHistory")
  callHistoriesReceived  CallHistory[] @relation("ReceiverHistory")
  recentContacts RecentContact[] @relation("RecentContactOwner")
  recentContactOf RecentContact[] @relation("RecentContactUser")
}

model Meeting {
  id           String   @id @default(cuid())
  meetingCode  String   @unique
  hostId       String
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  host User @relation(fields: [hostId], references: [id])
  participants MeetingParticipant[]
  calls Call[]
}

model MeetingParticipant {
  id          String    @id @default(cuid())
  meetingId   String
  userId      String?
  displayName String?
  email       String?
  avatar      String?
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([meetingId])
  @@index([userId])
}

model RecentContact {
  id                String   @id @default(cuid())
  userId            String
  contactUserId     String
  lastInteractionAt DateTime @default(now())

  user        User @relation("RecentContactOwner", fields: [userId], references: [id], onDelete: Cascade)
  contactUser User @relation("RecentContactUser", fields: [contactUserId], references: [id], onDelete: Cascade)

  @@unique([userId, contactUserId])
  @@index([lastInteractionAt])
}

model Call {
  id         String   @id @default(cuid())
  callerId   String
  receiverId String
  meetingId  String?
  callType   String?
  type       String   // "audio" | "video"
  status     String   // "ringing" | "completed" | "missed" | "rejected" | "cancelled"
  startedAt  DateTime?
  endedAt    DateTime?
  duration   Int?     // in seconds
  createdAt  DateTime @default(now())

  caller   User @relation("CallCaller", fields: [callerId], references: [id])
  receiver User @relation("CallReceiver", fields: [receiverId], references: [id])
  meeting  Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  histories CallHistory[]

  @@index([callerId, createdAt])
  @@index([receiverId, createdAt])
  @@index([meetingId])
}

model CallHistory {
  id        String   @id @default(cuid())
  callId    String
  callerId  String
  receiverId String
  status    String
  duration  Int?
  createdAt DateTime @default(now())

  call Call @relation(fields: [callId], references: [id])
  caller   User @relation("CallerHistory", fields: [callerId], references: [id])
  receiver User @relation("ReceiverHistory", fields: [receiverId], references: [id])
}
